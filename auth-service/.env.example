# Environment
ENV=development
DEBUG=True

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth_service

# JWT
JWT_SECRET_KEY=your-secret-key-change-this-in-production-must-be-at-least-32-chars
JWT_ALGORITHM=HS256

# Encryption Key (for storing Entra ID secrets)
ENCRYPTION_KEY=your-encryption-key-must-be-32-chars-0000000000000000

# Microsoft Entra ID
ENTRA_ID_TENANT_ID=
ENTRA_ID_CLIENT_ID=
ENTRA_ID_CLIENT_SECRET=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
LOGIN_RATE_LIMIT=5

# ── Email / SMTP (forgot-password) ──────────────────────────────────────────
# GoDaddy Workspace Email (default):
SMTP_HOST=mail.marketyantra.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
# If port 465 doesn't work, try STARTTLS on 587:
# SMTP_PORT=587
# SMTP_USE_SSL=false
# SMTP_USE_TLS=true

SMTP_USERNAME=noreply@marketyantra.com
SMTP_PASSWORD=your-email-password-here
EMAIL_FROM=noreply@marketyantra.com
EMAIL_FROM_NAME=authYantra

# Frontend base URL — used to build the reset link in the email
# Local dev: http://localhost:5173   |   Production: https://your-vps-domain.com
FRONTEND_URL=http://localhost:5173

# Reset token expiry in minutes (default: 60)
PASSWORD_RESET_EXPIRE_MINUTES=60
